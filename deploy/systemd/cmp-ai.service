[Unit]
Description=CMP AI Spring Boot Backend
After=network.target

[Service]
Type=simple
User=cmp-ai
WorkingDirectory=/opt/cmp-ai/backend
EnvironmentFile=/opt/cmp-ai/backend/.env
ExecStart=/usr/bin/java -jar /opt/cmp-ai/backend/cmp-ai.jar
Restart=always
RestartSec=5
SuccessExitStatus=143

[Install]
WantedBy=multi-user.target
